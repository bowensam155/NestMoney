# ============================================================
# NestMoney — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Variables prefixed EXPO_PUBLIC_ are bundled into the client.
# All other variables are Lambda-only — never reference in app/ or components/.
# ============================================================

# App environment
EXPO_PUBLIC_APP_ENV=development

# AWS API Gateway
EXPO_PUBLIC_API_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com/dev
EXPO_PUBLIC_WS_URL=wss://your-ws-id.execute-api.us-west-2.amazonaws.com/prod

# AWS Cognito (client-safe — public pool config only)
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-west-2_xxxxxxxxx
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_COGNITO_REGION=us-west-2

# AWS Region (Lambda runtime — not client)
AWS_REGION=us-west-2

# Unit.co — ALWAYS use sandbox keys locally, NEVER production
UNIT_API_KEY=your_unit_sandbox_key
UNIT_ENV=sandbox

# Anthropic (Lambda only — never reference in client code)
ANTHROPIC_API_KEY=sk-ant-...

# HeyGen (Lambda only — never reference in client code)
HEYGEN_API_KEY=your_heygen_key

# Aurora PostgreSQL (Lambda only — never reference in client code)
DB_HOST=your-aurora-cluster.cluster-xxxx.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=nestmoney
DB_USER=nestmoney_app
DB_PASSWORD=your_db_password
