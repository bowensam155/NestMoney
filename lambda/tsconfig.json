{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "../types/*": ["../types/*"],
      "../lib/*": ["../lib/*"]
    }
  },
  "include": [
    "**/*.ts",
    "../types/**/*.ts",
    "../lib/db.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
